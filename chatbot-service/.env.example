# OpenAI API Key (gerekli - LLM için)
# https://platform.openai.com/api-keys adresinden alın
# Bu olmadan chatbot mock modda çalışır (demo yanıtlar verir)
OPENAI_API_KEY=sk-...

# MySQL veritabanı bağlantısı (Spring Boot ile aynı credentials)
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/datapulse_ecommerce

# Chatbot servis portu (Spring Boot ChatController'da da aynı olmalı)
PORT=8000
